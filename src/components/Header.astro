---
import Menu from "./Menu.astro";
import Navigation from "./Navigation.astro";
---
<header>
  <div class="heading-and-menu">
    <a href="/" class="site-title">Exagram</a>
    <Menu />
    <nav class="large-nav">
      <Navigation />
    </nav>
  </div>
  <nav class="small-nav">
    <Navigation />
  </nav>
</header>
<style>
.heading-and-menu {
  display: flex;
  align-items: baseline;
  gap: 20px;
}
.large-nav {
  display: none;
}
.site-title {
  font-family: var(--font-fira-code);
  font-size: 2.5rem;
  font-weight: bold;
  display: inline-block;
  text-shadow:
    -1px -1px 0 #000,
    1px -1px 0 #000,
    -1px 1px 0 #000,
    1px 1px 0 #000;
}
a, a:active, a:focus, a:visited {
  color: var(--primary1);
  text-decoration: none;
  border: 1px;
}
:has(.menu[aria-expanded="true"]) :global(.nav-links) {
  display: unset;
}

@media screen and (min-width: 636px) {
  .large-nav {
    display: block;
  }
  .small-nav {
    display: none;
  }
}
</style>