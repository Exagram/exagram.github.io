---
import Tags from "./Tags.astro"

const { date, description, isFirst, tags, title, url } = Astro.props
---
<div class="post" class:list={[{'is-first': isFirst}]}>
	<div class="date">{date.toISOString().split('T')[0]}</div>
	<div class="content">
		<a href={url}><h2>{title}</h2></a>
		<p class="description">{description}</p>
		<Tags tags={tags} />
	</div>
</div>
<style>
	.post {
		display: flex;
		flex-direction: column;
		gap: 0;
		align-items: baseline;
	}
	.date {
		flex-shrink: 0;
		font-size: 1.0rem;
		color: #6c757d;
	}
	.post, h2 {
		margin-bottom: 0;
		margin-top: 0;
	}
	.description {
		margin-bottom: 0;
		margin-top: 0;
	}
	.post:not(.is-first) {
		margin-top: 20px;
	}
	@media screen and (min-width: 636px) {
		.post {
			flex-direction: row;
			gap: 20px;
		}
	}
</style>